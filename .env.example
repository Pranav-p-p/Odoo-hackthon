# Supabase Frontend Keys (from Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_[YOUR-KEY-HERE]

# Supabase PostgreSQL Connection String (for Prisma Backend)
# Replace [YOUR-PASSWORD] with the actual database password you created in Supabase
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# JWT Secret (for backend auth)
JWT_SECRET="your-super-secret-jwt-key"
