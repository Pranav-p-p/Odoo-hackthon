// ============================================================================
// AssetFlow — Prisma Schema
// Database: Supabase PostgreSQL
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING_APPROVAL
  APPROVED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum AuditStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum AuditItemStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

// ──────────────────────────────────────────────
// USERS & ORGANIZATION
// ──────────────────────────────────────────────

model Department {
  id               String           @id @default(uuid()) @db.Uuid
  name             String           @unique
  headId           String?          @map("head_id") @db.Uuid
  head             User?            @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
  parentDepartmentId String?        @map("parent_department_id") @db.Uuid
  parentDepartment Department?      @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments Department[]     @relation("DepartmentHierarchy")
  status           DepartmentStatus @default(ACTIVE)
  createdAt        DateTime         @default(now()) @map("created_at")

  users            User[]           @relation("UserDepartment")
  assets           Asset[]

  @@map("departments")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String
  phone        String?
  role         Role       @default(EMPLOYEE)
  status       UserStatus @default(ACTIVE)
  departmentId String?    @map("department_id") @db.Uuid
  department   Department? @relation("UserDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now()) @map("created_at")

  // Relations
  allocations           Allocation[]
  bookings              Booking[]
  headOfDepartments     Department[]           @relation("DepartmentHead")
  transfersRequested    Transfer[]             @relation("TransferRequester")
  transfersFrom         Transfer[]             @relation("TransferFrom")
  transfersTo           Transfer[]             @relation("TransferTo")
  maintenanceRequests   MaintenanceRequest[]   @relation("MaintenanceRequester")
  technicianAssignments MaintenanceRequest[]   @relation("MaintenanceTechnician")
  auditAssignments      AuditCycle[]           @relation("AuditAuditor")
  notifications         Notification[]
  activityLogs          ActivityLog[]

  @@map("users")
}

// ──────────────────────────────────────────────
// ASSETS
// ──────────────────────────────────────────────

model AssetCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  assets      Asset[]

  @@map("asset_categories")
}

model Asset {
  id              String        @id @default(uuid()) @db.Uuid
  assetTag        String        @unique @map("asset_tag") // Format: AF-0001
  serialNumber    String?       @map("serial_number")
  name            String
  categoryId      String        @map("category_id") @db.Uuid
  category        AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  departmentId    String?       @map("department_id") @db.Uuid
  department      Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  status          AssetStatus   @default(AVAILABLE)
  isBookable      Boolean       @default(false) @map("is_bookable")
  acquisitionDate DateTime?     @map("acquisition_date")
  acquisitionCost Float?        @map("acquisition_cost")
  condition       String?       // e.g. "Good", "Fair", "Poor"
  location        String?       // e.g. "Bengaluru", "HQ Floor 2", "Warehouse"
  photoUrl        String?       @map("photo_url")
  createdAt       DateTime      @default(now()) @map("created_at")

  allocations     Allocation[]
  transfers       Transfer[]
  bookings        Booking[]
  maintenanceReqs MaintenanceRequest[]
  auditItems      AuditItem[]

  @@map("assets")
}

// ──────────────────────────────────────────────
// TRANSACTIONS (Allocations & Transfers)
// ──────────────────────────────────────────────

model Allocation {
  id              String           @id @default(uuid()) @db.Uuid
  assetId         String           @map("asset_id") @db.Uuid
  asset           Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId          String           @map("user_id") @db.Uuid
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          AllocationStatus @default(ACTIVE)
  allocatedAt     DateTime         @default(now()) @map("allocated_at")
  expectedReturn  DateTime?        @map("expected_return")
  returnedAt      DateTime?        @map("returned_at")
  returnCondition String?          @map("return_condition") // Condition at check-in: "Good", "Fair", "Damaged"
  returnNotes     String?          @map("return_notes")     // Free-text check-in notes

  @@index([assetId, status])
  @@map("allocations")
}

model Transfer {
  id             String         @id @default(uuid()) @db.Uuid
  assetId        String         @map("asset_id") @db.Uuid
  asset          Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromUserId     String?        @map("from_user_id") @db.Uuid
  fromUser       User?          @relation("TransferFrom", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUserId       String?        @map("to_user_id") @db.Uuid
  toUser         User?          @relation("TransferTo", fields: [toUserId], references: [id], onDelete: SetNull)
  fromDeptId     String?        @map("from_dept_id") @db.Uuid
  toDeptId       String         @map("to_dept_id") @db.Uuid
  requestedById  String         @map("requested_by_id") @db.Uuid
  requestedBy    User           @relation("TransferRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedById   String?        @map("approved_by_id") @db.Uuid
  status         TransferStatus @default(REQUESTED)
  reason         String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("transfers")
}

// ──────────────────────────────────────────────
// OPERATIONS (Bookings & Maintenance)
// ──────────────────────────────────────────────

model Booking {
  id        String        @id @default(uuid()) @db.Uuid
  assetId   String        @map("asset_id") @db.Uuid
  asset     Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String        @map("user_id") @db.Uuid
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime DateTime      @map("start_time")
  endTime   DateTime      @map("end_time")
  status    BookingStatus @default(UPCOMING)
  purpose   String?
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([assetId, startTime])
  @@map("bookings")
}

model MaintenanceRequest {
  id               String              @id @default(uuid()) @db.Uuid
  assetId          String              @map("asset_id") @db.Uuid
  asset            Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  requestedById    String              @map("requested_by_id") @db.Uuid
  requestedBy      User                @relation("MaintenanceRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  issueDescription String              @map("issue_description")
  priority         MaintenancePriority @default(MEDIUM)
  status           MaintenanceStatus   @default(PENDING_APPROVAL)
  technicianId     String?             @map("technician_id") @db.Uuid
  technician       User?               @relation("MaintenanceTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  photoUrl         String?             @map("photo_url")
  resolvedNotes    String?             @map("resolved_notes")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@index([assetId, status])
  @@map("maintenance_requests")
}

// ──────────────────────────────────────────────
// INTELLIGENCE (Audit, Notifications, Logs)
// ──────────────────────────────────────────────

model AuditCycle {
  id             String      @id @default(uuid()) @db.Uuid
  name           String
  departmentId   String?     @map("department_id") @db.Uuid
  locationScope  String?     @map("location_scope") // e.g. "HQ Floor 2", "Warehouse"
  auditorId      String      @map("auditor_id") @db.Uuid
  auditor        User        @relation("AuditAuditor", fields: [auditorId], references: [id], onDelete: Cascade)
  status         AuditStatus @default(OPEN)
  startDate      DateTime    @map("start_date")
  endDate        DateTime    @map("end_date")
  createdAt      DateTime    @default(now()) @map("created_at")
  closedAt       DateTime?   @map("closed_at")

  items          AuditItem[]

  @@map("audit_cycles")
}

model AuditItem {
  id               String           @id @default(uuid()) @db.Uuid
  auditCycleId     String           @map("audit_cycle_id") @db.Uuid
  auditCycle       AuditCycle       @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  assetId          String           @map("asset_id") @db.Uuid
  asset            Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  expectedLocation String?          @map("expected_location")
  expectedStatus   AssetStatus      @map("expected_status")
  actualStatus     AuditItemStatus  @default(PENDING) @map("actual_status")
  notes            String?

  @@map("audit_items")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // Values from NotificationType in SHARED_ENUMS.md
  category  String   // Values: ALERTS, APPROVALS, BOOKINGS
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String   // e.g. "ASSET_REGISTERED", "ALLOCATION_CREATED"
  entityType  String   @map("entity_type") // e.g. "Asset", "Allocation", "Transfer"
  entityId    String   @map("entity_id")
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("activity_logs")
}
